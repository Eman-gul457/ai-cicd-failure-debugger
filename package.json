{
  "name": "ai-cicd-failure-debugger",
  "version": "1.0.0",
  "description": "ReleaseGuard API demo service for the AI CI/CD Failure Debugger portfolio project.",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run tests",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "devops",
    "cicd",
    "fastify",
    "typescript",
    "releaseguard"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "pino": "^10.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
